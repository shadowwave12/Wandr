<% layout('layouts/boilerplate') %>
<body>
  <section class="listings-collection">
    <div class="listings-collection__header">
      <div>
        <p class="eyebrow">Curated stays</p>
        <h3>All Listings</h3>
      </div>
      <span class="collection-count"><%= allListings.length %> stays</span>
    </div>
    <div class="row row-cols-md-2 row-cols-sm-1 row-cols-lg-3 g-4">
    <% for(let listing of allListings) { let image; try { image =
    JSON.parse(listing.image); } catch (e) { image = { url: listing.image }; }
    %>
    <a href="/listings/<%= listing._id %>" class="text-decoration-none">
      <div class="card col listing-card">
        <img
          src="<%= listing.image.url %>"
          class="card-img-top"
          alt="<%= listing.title %>"
          style="height: 18rem"
        />
        <div class="card-body">
          <h5 class="card-title"><%= listing.title %></h5>
          <p class="card-text">
            &#8377; <%= listing.price.toLocaleString("en-IN") %> /Night
          </p>
        </div>
      </div>
    </a>

    <% } %>
    </div>
  </section>
</body>
